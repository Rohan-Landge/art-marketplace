<!-- .htaccess file for security and SEO -->
<!-- Place this file in the root directory -->

# Enable mod_rewrite
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /art-marketplace/
    
    # Prevent direct access to sensitive folders
    RewriteRule ^(config|auth|includes)/ - [F,L]
    
    # Redirect HTTP to HTTPS (uncomment when deployed)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Disable directory listing
<IfModule mod_autoindex.c>
    Options -Indexes
</IfModule>

# Set character encoding
AddDefaultCharset UTF-8

# Set proper content types
<IfModule mod_mime.c>
    AddType image/svg+xml svg svgz
    AddEncoding gzip svgz
</IfModule>

# Set cache headers
<IfModule mod_expires.c>
    ExpiresActive On
    
    # Images
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType image/webp "access plus 1 year"
    
    # CSS and JavaScript
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    
    # HTML
    ExpiresByType text/html "access plus 1 day"
</IfModule>

# Prevent access to PHP files in upload directory
<IfModule mod_php.c>
    php_flag engine off
</IfModule>

<FilesMatch "\.php$">
    Order Deny,Allow
    Allow from all
</FilesMatch>
